{
  "name": "@ontology-of-freedom/ofbt",
  "version": "0.1.0",
  "description": "OWL ↔ FOL Bidirectional Translator — round-trip translation between OWL 2 DL and First-Order Logic against the v0.1.7 frozen specification",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "files": [
    "dist"
  ],
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./kernel": {
      "types": "./dist/kernel/index.d.ts",
      "import": "./dist/kernel/index.js"
    },
    "./errors": {
      "types": "./dist/kernel/errors.d.ts",
      "import": "./dist/kernel/errors.js"
    },
    "./reason-codes": {
      "types": "./dist/kernel/reason-codes.d.ts",
      "import": "./dist/kernel/reason-codes.js"
    },
    "./version": {
      "types": "./dist/kernel/version.d.ts",
      "import": "./dist/kernel/version.js"
    },
    "./session": {
      "types": "./dist/composition/session.d.ts",
      "import": "./dist/composition/session.js"
    }
  },
  "scripts": {
    "build": "tsc",
    "build:tests": "tsc -p tsconfig.test.json",
    "start": "node dist/adapters/cli.js",
    "cli": "node dist/adapters/cli.js",
    "test": "npm run build:tests && node dist-tests/tests/run-tests.js",
    "test:purity": "npm run build:tests && node dist-tests/scripts/ensure-kernel-purity.js",
    "test:corpus-manifest": "npm run build:tests && node dist-tests/scripts/check-corpus-manifest.js",
    "lint:arc": "node scripts/lint-arc.js",
    "build:arc": "node scripts/build-arc.js",
    "regenerate:arc-tsv": "node scripts/regenerate-arc-tsv.js",
    "test:arc-roundtrip": "node scripts/round-trip-arc.js",
    "refresh:vocab-cache": "node scripts/refresh-vocab-cache.js",
    "measure:bundle": "node scripts/measure-bundle.js",
    "ci": "npm run build && npm run test && npm run test:purity && npm run test:corpus-manifest",
    "clean": "rimraf dist dist-tests"
  },
  "keywords": [
    "owl",
    "fol",
    "first-order-logic",
    "tau-prolog",
    "json-ld",
    "deterministic",
    "edge-computing",
    "offline-first",
    "bfo",
    "ontology"
  ],
  "repository": {
    "type": "git",
    "url": ""
  },
  "homepage": "",
  "author": "",
  "license": "MIT",
  "dependencies": {
    "rdf-canonize": "^5.0.0"
  },
  "peerDependencies": {
    "tau-prolog": "0.3.4"
  },
  "peerDependenciesMeta": {
    "tau-prolog": {
      "optional": false
    }
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "esbuild": "^0.28.0",
    "rimraf": "^6.0.0",
    "typescript": "^5.7.0"
  },
  "engines": {
    "node": ">=22.0.0"
  }
}
